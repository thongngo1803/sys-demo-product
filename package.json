{
  "name": "sys-demo-product",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Small product demo that consumes @sys packages through injected seams.",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "demo": "node --env-file=.env dist/demo.js",
    "start": "node --env-file=.env dist/server.js",
    "check": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@sys/consent": "file:./vendor/consent",
    "@sys/sentinel": "file:./vendor/sentinel",
    "@sys/warp": "file:./vendor/warp"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  }
}
